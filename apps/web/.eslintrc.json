{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "settings": {
    "react": { "version": "detect" }
  },
  "plugins": ["react-hooks"],
  "ignorePatterns": [
    "components/mockups/**",
    "app/admin/whatsapp-groups/**",
    "app/clients/**/library/**"
  ],
  "reportUnusedDisableDirectives": false,
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "rules": {
    "react-hooks/rules-of-hooks": "error",
    "react-hooks/exhaustive-deps": "off"
  },
  "overrides": [
    {
      "files": ["**/*.ts", "**/*.tsx"],
      "parser": "@typescript-eslint/parser",
      "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module",
        "ecmaFeatures": { "jsx": true }
      }
    }
  ]
}
