{
  "name": "edro-digital-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @edro/backend dev",
    "dev:backend": "pnpm --filter @edro/backend dev",
    "dev:web": "pnpm --filter @edro/web dev",
    "build": "pnpm -r build",
    "build:backend": "pnpm --filter @edro/backend build",
    "build:web": "pnpm --filter @edro/web build",
    "start": "pnpm --filter @edro/backend start",
    "start:web": "pnpm --filter @edro/web start",
    "lint": "pnpm --filter @edro/backend lint || true && pnpm --filter @edro/web lint || true && pnpm --filter @edro/web-freelancer lint || true && pnpm --filter @edro/web-cliente lint || true",
    "security:repo": "node scripts/security/check-repo-security.mjs",
    "security:deploy": "node scripts/security/check-deploy-env.mjs",
    "typecheck": "pnpm --filter @edro/backend typecheck && pnpm --filter @edro/web typecheck && pnpm --filter @edro/web-freelancer typecheck",
    "verify:build": "pnpm --filter @edro/web build && pnpm --filter @edro/web-cliente build && pnpm --filter @edro/web-freelancer build",
    "security:verify": "pnpm security:repo && pnpm typecheck && pnpm verify:build",
    "migrate": "pnpm --filter @edro/backend db:migrate || true",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.3.5",
      "minimatch": ">=9.0.7",
      "rollup": ">=4.59.0",
      "flatted": ">=3.4.2",
      "undici": ">=7.24.0",
      "underscore": ">=1.13.8",
      "bn.js": ">=4.12.3",
      "diff": ">=4.0.4",
      "picomatch": ">=2.3.2",
      "brace-expansion": ">=2.0.3",
      "yaml": ">=1.10.3",
      "dompurify": ">=3.3.2"
    }
  },
  "devDependencies": {
    "ajv": "^6.12.6",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^7.0.3",
    "vitest": "^4.0.18"
  }
}
