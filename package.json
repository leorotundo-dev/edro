{
  "name": "edro-digital-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @edro/backend dev",
    "dev:backend": "pnpm --filter @edro/backend dev",
    "dev:web": "pnpm --filter @edro/web dev",
    "build": "pnpm -r build",
    "build:backend": "pnpm --filter @edro/backend build",
    "build:web": "pnpm --filter @edro/web build",
    "start": "pnpm --filter @edro/backend start",
    "start:web": "pnpm --filter @edro/web start",
    "lint": "pnpm --filter @edro/backend lint || true && pnpm --filter @edro/web lint || true",
    "migrate": "pnpm --filter @edro/backend db:migrate || true",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
